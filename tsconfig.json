{
  "compilerOptions": {
    "outDir": "build",
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0"
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "build"]
}
